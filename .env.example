# ============================================================
# Heaven Church Admin - Environment Variables
# Copy this to .env.local for local development
# Set these in Railway > Project > Variables for production
# ============================================================

# ---- DATABASE (auto-provided by Railway PostgreSQL plugin) ----
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ---- APP SECRETS ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-this"

# ---- APP URL ----
# Set to your Railway domain after first deploy
NEXTAUTH_URL="https://your-app.railway.app"
APP_URL="https://your-app.railway.app"

# ---- ADMIN CREDENTIALS ----
# Used to create the first admin user on startup
# CHANGE THESE BEFORE DEPLOYING!
ADMIN_USERNAME="Admin"
ADMIN_PASSWORD="ChangeThisPassword2025!"

# ---- CHURCH SETTINGS ----
CHURCH_NAME="Horsens Pinsekirke"

# ---- EMAIL / SMTP (optional but recommended) ----
# Used for: cleaning reminders, follow-up emails, bulk emails
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx  (App Password - NOT your normal password!)
#   See: https://myaccount.google.com/apppasswords
#
# Outlook / Hotmail:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USER=your@outlook.com
#   SMTP_PASS=your-password
#
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
# SMTP_SECURE="false"  # Set to "true" for port 465 (SSL), leave false for port 587 (STARTTLS)

# ---- TRANSLATE ADMIN ----
# Initial translator access code (can be changed in the Translate Admin page)
# Translators use this code + their name to log in at /?page=translate
TRANSLATE_CODE="KIRKE2025"
